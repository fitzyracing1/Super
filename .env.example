# Copy to .env and fill in. Do NOT commit real secrets.

# --- Agent behavior ---
SUPERUSER_HUMAN_OWNER=you@example.com
SUPERUSER_APPROVAL_AT=MEDIUM
SUPERUSER_AUDIT_LOG=superuser-audit.log
SUPERUSER_COMMAND_TIMEOUT=60
# SUPERUSER_CONFIG=superuser.yaml

# --- Cisco AI Defense ---
AI_DEFENSE_ENABLED=true
AI_DEFENSE_MODE=enforce
# Inspection API key (explicit MCP tool-call inspection):
AI_DEFENSE_INSPECTION_API_KEY=
# Agent Runtime (agentsec.protect) API mode:
AI_DEFENSE_API_MODE_LLM_ENDPOINT=
AI_DEFENSE_API_MODE_LLM_API_KEY=
# Or point at an agentsec.yaml instead of the two vars above:
# AI_DEFENSE_AGENTSEC_CONFIG=agentsec.yaml

# --- Cisco Duo Agentic Identity (per-tool-call authorization) ---
DUO_ENABLED=false
DUO_MODE=enforce
DUO_AGENT_ID=superuser-agent-1
# OAuth 2.1 client-credentials (machine-to-machine) endpoint + creds:
DUO_TOKEN_URL=
DUO_CLIENT_ID=
DUO_CLIENT_SECRET=
# Space-separated scopes requested at token time:
DUO_SCOPES=superuser.read superuser.exec
# RFC 8707 resource indicator (audience this agent may access):
DUO_RESOURCE=
# Optional explicit per-tool-call decision endpoint (else scope-based):
DUO_AUTHORIZATION_URL=

# --- Stripe usage-based (metered) billing ---
STRIPE_ENABLED=false
STRIPE_API_KEY=
STRIPE_CUSTOMER_ID=
STRIPE_METER_EVENT_NAME=superuser_tool_call
STRIPE_DEFAULT_VALUE=1

# --- GitHub (least-privilege, fine-grained token) ---
GITHUB_TOKEN=
GITHUB_ALLOWED_REPOS=your-org/your-repo
GITHUB_ALLOW_WRITES=false
