# Copy to .env and fill in. Do NOT commit real secrets.

# --- Agent behavior ---
SUPERUSER_HUMAN_OWNER=you@example.com
SUPERUSER_APPROVAL_AT=MEDIUM
SUPERUSER_AUDIT_LOG=superuser-audit.log
SUPERUSER_COMMAND_TIMEOUT=60
# SUPERUSER_CONFIG=superuser.yaml

# --- Cisco AI Defense ---
AI_DEFENSE_ENABLED=true
AI_DEFENSE_MODE=enforce
# Inspection API key (explicit MCP tool-call inspection):
AI_DEFENSE_INSPECTION_API_KEY=
# Agent Runtime (agentsec.protect) API mode:
AI_DEFENSE_API_MODE_LLM_ENDPOINT=
AI_DEFENSE_API_MODE_LLM_API_KEY=
# Or point at an agentsec.yaml instead of the two vars above:
# AI_DEFENSE_AGENTSEC_CONFIG=agentsec.yaml

# --- GitHub (least-privilege, fine-grained token) ---
GITHUB_TOKEN=
GITHUB_ALLOWED_REPOS=your-org/your-repo
GITHUB_ALLOW_WRITES=false
